    {
      "parameters": {
        "jsCode": "function safeAll(nodeName) {\n  try {\n    return $(nodeName).all().map(i => i.json);\n  } catch (e) {\n    return [];\n  }\n}\n\nconst rows = [\n  ...safeAll('abstencionPasada'),\n  ...safeAll('fallaAlucinacion'),\n  ...safeAll('fallaSobreabstencion'),\n  ...safeAll('respuestaPasable'),\n  ...safeAll('fallaRespuestaCalidad'),\n];\n\nconst total_cases = rows.length;\nconst passed_answered = rows.filter(r => r.evaluation === 'passed_answered').length;\nconst passed_abstention = rows.filter(r => r.evaluation === 'passed_abstention').length;\nconst failed_hallucinated = rows.filter(r => r.evaluation === 'failed_hallucinated').length;\nconst failed_over_abstention = rows.filter(r => r.evaluation === 'failed_over_abstention').length;\nconst failed_answer_quality = rows.filter(r => r.evaluation === 'failed_answer_quality').length;\n\nconst average_latency_ms = total_cases\n  ? Math.round(rows.reduce((acc, r) => acc + (r.latency_ms || 0), 0) / total_cases)\n  : 0;\n\nreturn [\n  {\n    json: {\n      total_cases,\n      passed_answered,\n      passed_abstention,\n      failed_hallucinated,\n      failed_over_abstention,\n      failed_answer_quality,\n      average_latency_ms,\n      results: rows\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
