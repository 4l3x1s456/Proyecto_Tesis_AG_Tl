      "name": "fallaRespuestaCalidad"
    },
    {
      "parameters": {
        "jsCode": "const noInfoMessage = 'no encontre suficiente informacion en la base de conocimiento para responder tu pregunta.';\n\nreturn $input.all().map((item, i) => {\n  const resultadoCaso = $('ResultadoCaso').itemMatching(i).json;\n\n  const answer = (resultadoCaso.answer || '').trim();\n  const normalizedAnswer = answer\n    .toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .trim();\n\n  const retrievedChunksCount = Number(\n    resultadoCaso.retrieved_chunks_count ??\n    resultadoCaso.sources_count ??\n    0\n  );\n\n  const minSources = Number(\n    item.json.min_sources ??\n    resultadoCaso.min_sources ??\n    0\n  );\n\n  const keywordCoverage = Number(resultadoCaso.keyword_coverage || 0);\n  const hasContextSupport = resultadoCaso.sufficient_context === true;\n  const hasKeywordSupport = keywordCoverage >= 0.5;\n  const hasMinSources = retrievedChunksCount >= minSources;\n  const isNoInfoMessage = normalizedAnswer === noInfoMessage;\n  const looksAnswered = !isNoInfoMessage && answer.length > 0;\n  const expectsAbstention = item.json.expects_abstention ?? false;\n  const abstained = resultadoCaso.abstained === true;\n\n  const isAbstentionEffective = abstained || isNoInfoMessage;\n\n  const shouldBeOverAbstentionCandidate =\n    !expectsAbstention &&\n    isAbstentionEffective &&\n    hasContextSupport &&\n    hasMinSources;\n\n  const answerQualityReady =\n    !expectsAbstention &&\n    !isAbstentionEffective &&\n    hasContextSupport &&\n    hasMinSources &&\n    hasKeywordSupport &&\n    looksAnswered;\n\n  let classificationHint = 'undetermined';\n  let reasonHint = 'needs_review';\n\n  if (expectsAbstention && isAbstentionEffective) {\n    classificationHint = 'passed_abstention';\n    reasonHint = 'expected_abstention_met';\n  } else if (expectsAbstention && !isAbstentionEffective) {\n    classificationHint = 'failed_hallucinated';\n    reasonHint = 'answered_when_should_abstain';\n  } else if (shouldBeOverAbstentionCandidate) {\n    classificationHint = 'failed_over_abstention';\n    reasonHint = 'abstained_despite_sufficient_context';\n  } else if (answerQualityReady) {\n    classificationHint = 'passed_answered';\n    reasonHint = 'response_with_sufficient_context';\n  } else if (!expectsAbstention) {\n    classificationHint = 'failed_answer_quality';\n    reasonHint = 'answer_quality_not_met';\n  }\n\n  return {\n    json: {\n      ...item.json,\n      ...resultadoCaso,\n      min_sources: minSources,\n      retrieved_chunks_count: retrievedChunksCount,\n      normalized_answer: normalizedAnswer,\n      answer_length: answer.length,\n      expects_abstention: expectsAbstention,\n      is_no_info_message: isNoInfoMessage,\n      has_context_support: hasContextSupport,\n      has_keyword_support: hasKeywordSupport,\n      has_min_sources: hasMinSources,\n      looks_answered: looksAnswered,\n      is_abstention_effective: isAbstentionEffective,\n      should_be_over_abstention_candidate: shouldBeOverAbstentionCandidate,\n      answer_quality_ready: answerQualityReady,\n      classification_hint: classificationHint,\n      reason_hint: reasonHint\n    },\n    pairedItem: { item: i }\n  };\n});"
      },
